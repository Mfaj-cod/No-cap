# NoCaps E-Commerce Store Configuration

# Store Configuration
STORE_NAME=NoCaps

# Session & Security
SESSION_SECRET=your-secret-key-change-in-production
SECRET_KEY=your-secret-key-change-in-production

# Database (optional, defaults to store.db)
# DATABASE_PATH=./store.db

# Razorpay Payment Gateway (for online payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Email Service - SMTP (Gmail, SendGrid, etc.)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
OWNER_EMAIL=store-owner@example.com

# AI Support - Groq API (for CapAI customer support)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: For higher email reliability via Resend API
# Install: pip install resend
# Get key from: https://resend.com/api-keys
# RESEND_API_KEY=re_your_resend_api_key

